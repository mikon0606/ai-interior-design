{
  "name": "ai-interior-design",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "nodeVersion": "20.18.0",
  "headers": [
    {
      "source": "/_next/static/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
